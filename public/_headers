# Cache strategies for hashed static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache strategies for user-uploaded static media (validate daily)
/static/*
  Cache-Control: public, max-age=86400, must-revalidate

# Cache strategies for dynamic configurations and index pages
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/*.json
  Cache-Control: public, max-age=0, must-revalidate
/*.xml
  Cache-Control: public, max-age=0, must-revalidate

# Global security response headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; media-src 'self' data: https:; connect-src 'self' https:; font-src 'self' data: https:;
